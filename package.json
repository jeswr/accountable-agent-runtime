{
  "name": "@jeswr/accountable-agent-runtime",
  "version": "0.1.0",
  "description": "Reference accountable-agent runtime — the Accountable Web of Agents §4 scenario made executable: a delegated agent negotiates, acts, and leaves a verifiable on-pod accountability trace. Composes @jeswr/solid-vc + solid-agent-card + solid-a2a + solid-odrl (agent-delegation profile) and adds the composed four-phase chain verifier (G7).",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/accountable-agent-runtime.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "accountable-agent-runtime": "./dist/cli.js"
  },
  "files": ["dist", "README.md", "docs", "BUILD-PLAN.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:dist": "node scripts/check-dist-fresh.mjs",
    "check:lockfile-transport": "node scripts/check-lockfile-transport.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src test scripts && npm run check:lockfile-transport",
    "lint:fix": "biome check --write src test scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:live": "node dist/cli.js demo",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@jeswr/agent-authz-verifier": "github:jeswr/agent-authz-verifier#e153710a9082373c6709373ca4d9aa40500c7aa3",
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/guarded-fetch": "github:jeswr/guarded-fetch#bd4490927fd36d62f6b78a0021e8d40bbb572c3b",
    "@jeswr/solid-dpop": "github:jeswr/solid-dpop#2bc52bb45d8be70b878f7a5d49082f656c6a3b4f",
    "@solid/object": "^0.6.0",
    "@jeswr/solid-a2a": "git+https://github.com/jeswr/solid-a2a.git#e5ff315c2c4c44eb1d83679c22da95696f3ba8b7",
    "@jeswr/solid-agent-card": "git+https://github.com/jeswr/solid-agent-card.git#0947037a16e1b7618cc5547aaf678a7bb4b4152d",
    "@jeswr/solid-odrl": "git+https://github.com/jeswr/solid-odrl.git#db97922d82f2ec016b7ef705827cf85429458668",
    "@jeswr/solid-vc": "git+https://github.com/jeswr/solid-vc.git#7f7a4e0a5ded7415ac40d63f2ff54077863df14e",
    "@rdfjs/wrapper": "^0.34.0",
    "n3": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.21.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
